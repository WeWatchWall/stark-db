{
   "name": "stark-db",
   "version": "0.7.2",
   "description": "Persistent SQL engine with TypeScript APIs for quick and easy production apps.",
   "main": "./dist/src/stark-db.js",
   "types": "./dist/src/stark-db.d.ts",
   "scripts": {
      "clean": "node clean.js dist build package",
      "lint": "eslint ./ --ext .js,.jsx,.ts,.tsx",
      "lint:fix": "eslint ./ --ext .js,.jsx,.ts,.tsx --fix",
      "build": "tsc",
      "build-all": "npm run clean && npm run build",
      "prepare": "npm run build",
      "test": "ts-mocha test/**/*.test.ts",
      "updatePublish": "node publish.js",
      "start": "ts-node src/index.ts",
      "typeorm": "typeorm-ts-node-commonjs"
   },
   "keywords": [
      "database",
      "typescript"
   ],
   "author": "Adrian Burlacu <adrian.burlacu@live.com>",
   "license": "ISC",
   "repository": {
      "type": "git",
      "url": "https://github.com/WeWatchWall/stark-db.git"
   },
   "devDependencies": {
      "@types/chai": "^4.3.0",
      "@types/mocha": "^9.1.0",
      "@types/node": "^16.11.10",
      "@typescript-eslint/eslint-plugin": "^4.32.0",
      "@typescript-eslint/parser": "^4.32.0",
      "chai": "^4.3.4",
      "eslint": "^7.32.0",
      "fast-copy": "^3.0.0",
      "fast-fuzz": "^5.1.1",
      "latest-version": "^6.0.0",
      "mocha": "^9.1.2",
      "ts-mocha": "^9.0.2",
      "ts-node": "10.7.0"
   },
   "dependencies": {
      "fast-fuzz-shim": "^1.0.0",
      "flat-promise": "^1.0.3",
      "javascript-state-machine": "^3.1.0",
      "localforage": "^1.10.0",
      "objectmodel": "^4.3.1",
      "recursive-iterator": "^3.3.0",
      "reflect-metadata": "^0.1.13",
      "sql.js": "^1.8.0",
      "sqlite-parser": "^1.0.1",
      "sqlite3": "^5.1.2",
      "typeorm": "https://github.com/WeWatchWall/stark-db/raw/main/typeorm-0.3.10.tgz"
   }
}
